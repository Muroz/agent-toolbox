#!/usr/bin/env bash
# Launcher/multiplexer for the claude-performance-tracker CLI. Added to PATH when
# the plugin is installed, and also invoked directly by the hooks. Resolves the
# bundled scripts relative to itself, so it works in both installed and
# --plugin-dir dev modes with no CLAUDE_PLUGIN_* env var.
#
#   cpt ingest --event <Hook> ...   -> ingest.py   (used by the hooks)
#   cpt track  start|done ...       -> track.py
#   cpt report [view] ...           -> report.py
#   cpt eval   list-unjudged|context|persist ...  -> evaluate.py
#
# Python resolution: a project may pin an uninstalled version via a pyenv
# `.python-version`, which makes a bare `python3` (the pyenv shim) fail before
# our code runs. The plugin's scripts are stdlib-only and run on any Python 3.9+,
# so we force pyenv's `system` interpreter (harmless when pyenv is absent).
# Override with CPT_PYTHON=/path/to/python3 if needed.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
scripts="$here/../scripts"
export PYENV_VERSION="${PYENV_VERSION:-system}"
py="${CPT_PYTHON:-python3}"
sub="${1:-}"
shift || true
case "$sub" in
  ingest) exec "$py" "$scripts/ingest.py" "$@" ;;
  track)  exec "$py" "$scripts/track.py" "$@" ;;
  report) exec "$py" "$scripts/report.py" "$@" ;;
  eval)   exec "$py" "$scripts/evaluate.py" "$@" ;;
  *) echo "usage: cpt {ingest|track|report|eval} ..." >&2; exit 2 ;;
esac
